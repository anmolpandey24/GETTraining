<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="
          http://www.springframework.org/schema/beans
          http://www.springframework.org/schema/beans/spring-beans.xsd">
          
          
          <bean id="cust" class="com.coforge.beans.Customer">
          
          <constructor-arg name="cname" value="Rahul"></constructor-arg>
          <constructor-arg name="cid" value="1"></constructor-arg>
          
          <constructor-arg name="mobile" value="89898989"></constructor-arg>
          <constructor-arg name="email" value="rahul@gmail.com"></constructor-arg>
          <constructor-arg name="address" ref="address"></constructor-arg>
          
          </bean>
          
           <bean id="cust1" class="com.coforge.beans.Customer">
          <constructor-arg name="cname" value="Rohit"></constructor-arg>
          <constructor-arg name="cid" value="2"></constructor-arg>
          
          <constructor-arg name="mobile" value="898989777"></constructor-arg>
          <constructor-arg name="email" value="rohit@gmail.com"></constructor-arg>
          <constructor-arg name="address" ref="address1"></constructor-arg>
          
          </bean>
          
          <bean id="address" name="address" class="com.coforge.beans.Address">
          <constructor-arg name="hno" value="546"></constructor-arg>
          <constructor-arg name="street" value="6"></constructor-arg>
          <constructor-arg name="city" value="Noida"></constructor-arg>
          <constructor-arg name="state" value="UP"></constructor-arg>
          <constructor-arg name="pincode" value="201310"></constructor-arg>
          
          
          </bean>
          
          <bean id="address1"  class="com.coforge.beans.Address">
          <constructor-arg name="hno" value="789"></constructor-arg>
          <constructor-arg name="street" value="7"></constructor-arg>
          <constructor-arg name="city" value="Delhi"></constructor-arg>
          <constructor-arg name="state" value="UP"></constructor-arg>
          <constructor-arg name="pincode" value="111111"></constructor-arg>
          
          
          </bean>
          
          
   <!-- bean definitions here -->
</beans>